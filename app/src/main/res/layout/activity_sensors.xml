<!--                    android:layout_height="wrap_content" android:text="Sports"-->
<!--                    style="@style/Widget.MaterialComponents.Chip.Filter"/>-->
<!--            </com.google.android.material.chip.ChipGroup>-->

            <!-- Available Sensors List -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="📱 Device Sensors" android:textSize="18sp" android:textStyle="bold"/>

            <TextView android:id="@+id/tvSensorList"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>