<resources>

    <!-- Light theme EditText style -->
    <style name="AppEditTextStyle" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">#888888</item>
    </style>

    <!-- Dark theme EditText style -->
    <style name="AppEditTextStyle.Night" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#AAAAAA</item>
    </style>

    <!-- TextInputLayout hint color fix -->
    <style name="AppTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextColor">@color/purple_700</item>
        <item name="boxStrokeColor">@color/purple_700</item>
        <item name="android:textColorHint">#888888</item>
    </style>

</resources>